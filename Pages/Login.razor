@page "/login"
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager nav

<div class="container mt-4">
    <div class="col-md-5 mx-auto card p-4 shadow">
        <h3 class="text-center">Ingreso al Sistema</h3>
        
        <div class="mb-3">
            <label class="form-label">Usuario</label>
            <input @bind="usuario" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input @bind="pass" type="password" class="form-control" />
        </div>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="alert @(esExito ? "alert-success" : "alert-danger")">@mensaje</div>
        }

        <button class="btn btn-primary w-100" @onclick="Validar">Ingresar</button>
    </div>
</div>

@code {
    private string usuario = "";
    private string pass = "";
    private string mensaje = "";
    private bool esExito = false;

    private void Validar()
    {
        if (usuario == "alumno" && pass == "1234")
        {
            esExito = true;
            mensaje = "¡Bienvenido! Redirigiendo...";
            //nav.NavigateTo("/");
        }
        else
        {
            esExito = false;
            mensaje = "Credenciales incorrectas.";
        }
    }
}